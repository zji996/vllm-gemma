# Copy this file to `.env` and fill in your own values.

# ModelScope Access Token from https://modelscope.cn/my/myaccesstoken
MODELSCOPE_ACCESS_TOKEN=ms-your-token-here
# Backward-compatible alias for older scripts:
# MODELSCOPE_API_TOKEN=ms-your-token-here

# vLLM/OpenAI-compatible service API key used by `./vllm.sh start`
# Copy to `.env` and change it there if you do not want the default `abc123`.
API_KEY=abc123

# OpenAI-compatible served model name exposed by vLLM
SERVED_MODEL_NAME=gemma

MS_USERNAME=kuohao
MS_REPO_NAME=gemma-4-26B-A4B-it-FP8

# Optional overrides
# MS_REPO_ID=kuohao/gemma-4-26B-A4B-it-FP8
# SRC_DIR=/home/zji/docker/vllm-gemma/.cache/modelscope/kuohao/gemma-4-26B-A4B-it-FP8
# UPLOAD_METHOD=auto
# MAX_WORKERS=8
# COMMIT_MESSAGE=Upload FP8 model files
