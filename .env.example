# Copy this file to `.env` and fill in your own values.

# ModelScope Access Token from https://modelscope.cn/my/myaccesstoken
MODELSCOPE_ACCESS_TOKEN=ms-your-token-here
# Backward-compatible alias for older scripts:
# MODELSCOPE_API_TOKEN=ms-your-token-here

# vLLM/OpenAI-compatible service API key used by `./vllm.sh start`
# Leave empty for local-only no-auth mode, or set one before exposing the port.
API_KEY=

# OpenAI-compatible served model name exposed by vLLM
SERVED_MODEL_NAME=gemma

# Local OpenAI-compatible endpoint published by docker compose / vllm.sh
VLLM_HOST=127.0.0.1
VLLM_BIND_HOST=127.0.0.1
VLLM_HOST_PORT=8000

# Default ModelScope repo used by `./vllm.sh start gemma26b`
MS_GEMMA26B_MODEL_ID=kuohao/gemma-4-26B-A4B-it-FP8
# Model sync policy used by `./vllm.sh start|restart`
# if_missing: download only when local snapshot is absent
# always: sync from ModelScope on every start/restart
# never: require the local snapshot to already exist
VLLM_MODEL_SYNC_POLICY=if_missing

# Default BF16 source model used by `./download-model.sh`
DOWNLOAD_MODEL_ID=google/gemma-4-26B-A4B-it

MS_USERNAME=kuohao
MS_REPO_NAME=gemma-4-26B-A4B-it-FP8

# Optional overrides
# MS_GEMMA26B_MODEL_PATH=/root/.cache/modelscope/kuohao/gemma-4-26B-A4B-it-FP8
# MS_REPO_ID=kuohao/gemma-4-26B-A4B-it-FP8
# SRC_DIR=./.cache/modelscope/kuohao/gemma-4-26B-A4B-it-FP8
# UPLOAD_METHOD=auto
# MAX_WORKERS=8
# COMMIT_MESSAGE=Upload FP8 model files
